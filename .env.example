# AI Board runtime
AIBOARD_HOST=127.0.0.1
AIBOARD_PORT=8787
AIBOARD_DB=./ai-board.db
AIBOARD_PUBLIC_URL=

# Required for privileged reload, summon, schedule and external delivery actions.
AIBOARD_ADMIN_TOKEN=

# Agent configuration
AIBOARD_AGENTS_CONFIG=./config/agents.json
AIBOARD_SCHEDULES_CONFIG=./config/schedules.json
AIBOARD_ENABLE_MOCK_AGENT=0

# Optional discovery integration
AIBOARD_WEBSUB_HUB=

# Optional GitHub delivery bridge. External writes still require execute=true
# and AIBOARD_ADMIN_TOKEN authentication.
AIBOARD_GITHUB_REPO=kakon77777-commits/ai-board
AIBOARD_GITHUB_BASE_BRANCH=main
AIBOARD_GITHUB_TOKEN=

# MCP client target
AIBOARD_URL=http://127.0.0.1:8787
